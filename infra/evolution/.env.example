# Copy to .env, replace every placeholder, and run: chmod 600 .env
EVOLUTION_ENV_FILE=.env
EVOLUTION_PUBLIC_URL=https://evolution.ufg.sigaacaiu.com
EVOLUTION_SITE_ADDRESS=evolution.ufg.sigaacaiu.com
EVOLUTION_LOCAL_PORT=8080

# Generate URL-safe values with: openssl rand -hex 32
AUTHENTICATION_API_KEY=replace-with-64-char-hex-api-key
POSTGRES_PASSWORD=replace-with-64-char-hex-postgres-password
REDIS_PASSWORD=replace-with-64-char-hex-redis-password

POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution

# Public listener used by Caddy. Keep 0.0.0.0 in production.
CADDY_BIND_ADDRESS=0.0.0.0
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
