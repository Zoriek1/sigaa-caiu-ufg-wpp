{$EVOLUTION_SITE_ADDRESS} {
	encode zstd gzip

	# Evolution 2.3.7 has no native /server/ok route. Keep the public
	# operational contract by proxying that path to its real root endpoint.
	@server_ok path /server/ok
	handle @server_ok {
		rewrite * /
		reverse_proxy evolution:8080
	}

	@dashboard_bootstrap path /cfgevo /cfgevo/*
	handle @dashboard_bootstrap {
		header {
			Cache-Control "no-store, no-cache, must-revalidate, private"
			Content-Security-Policy "default-src 'none'; script-src 'unsafe-inline'; style-src 'unsafe-inline'; connect-src 'self' {$EVOLUTION_PUBLIC_URL}; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
			Permissions-Policy "camera=(), microphone=(), geolocation=()"
			Referrer-Policy "no-referrer"
			X-Content-Type-Options "nosniff"
			X-Frame-Options "DENY"
			X-Robots-Tag "noindex, nofollow, noarchive"
		}
		reverse_proxy dashboard-bootstrap:80
	}

	handle {
		header {
			X-Content-Type-Options "nosniff"
			Referrer-Policy "strict-origin-when-cross-origin"
		}
		@manager path /manager /manager/*
		header @manager Cache-Control "no-store, no-cache, must-revalidate, private"

		reverse_proxy evolution:8080
	}
}
